# Este es un archivo de ejemplo. Copia este archivo a .env y rellena los valores.
# No subas el archivo .env a Git.

# URL de conexión para la base de datos MySQL
# Reemplaza 'user', 'password', 'host', 'port', y 'cms_db' con tus datos reales.
DATABASE_URL="mysql+mysqlconnector://user:password@host:port/cms_db"

# Clave secreta para la generación de tokens JWT.
# Puedes generar una clave segura usando: openssl rand -hex 32
SECRET_KEY="your_super_secret_key_goes_here"
